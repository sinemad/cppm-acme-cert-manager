# ─────────────────────────────────────────────────────────────────────────────
# ClearPass Certificate Manager – Environment Variable Reference
#
# Copy this file to .env before first run:
#   cp env-example .env   (setup.sh does this automatically)
#   chmod 600 .env
#
# NEVER commit .env to source control.
# This file (env-example) is safe to commit: it contains no credentials.
#
# ── Configuration model ───────────────────────────────────────────────────────
#
# ClearPass server credentials, DNS provider, domain, and ACME settings are
# managed through the web UI (Servers page) and stored in:
#   /opt/cppm-certs/servers.json
#
# The variables below are the only ones that still need to be in .env — they
# control container-level behaviour and docker-compose port mappings that must
# be known before the container starts.
#
# ─────────────────────────────────────────────────────────────────────────────


# ── Timezone ──────────────────────────────────────────────────────────────────
# Container timezone. Used in log timestamps and cron scheduling.
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/New_York


# ── Web UI ────────────────────────────────────────────────────────────────────
# Port for the web interface.
# Must match the host-side port in docker-compose.yml (it does by default).
# Browse to http://<docker-host>:STATUS_PORT/ after the container starts.
STATUS_PORT=8080

# Set to true to require sign-in before the certificate dashboard is visible.
# The Servers and Users pages always require authentication regardless.
REQUIRE_AUTH_FOR_STATUS=false

# Web UI session lifetime in hours. Default: 8.
# SESSION_LIFETIME_HOURS=8


# ── Certificate upload callback ───────────────────────────────────────────────
# Port used by the temporary HTTP server that delivers the PKCS12 to ClearPass
# during certificate upload. Must match the host-side port in docker-compose.yml.
#
# The callback HOST (Docker host LAN IP that ClearPass can route to) is set
# per-server in the web UI under Servers → Add/Edit Server.
CPPM_CALLBACK_PORT=8765


# ── Operational flags ─────────────────────────────────────────────────────────
# Force certificate re-issuance on the next container start.
# Set to true, restart the container, then set back to false.
FORCE_RENEW=false

# Issue/renew certificates without uploading to ClearPass.
# Useful for testing the issuance workflow independently.
SKIP_UPLOAD=false

# Python log level for clearpass_upload.py.
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# ── Legacy migration (optional) ───────────────────────────────────────────────
# These variables are no longer required. If servers.json is empty on first
# startup and DOMAIN + CPPM_HOST are set here, the container will auto-create
# the first server entry from these values as a one-time migration.
# After that, manage everything through the web UI.
#
# DOMAIN=cppm.example.com
# ACME_EMAIL=admin@example.com
# ACME_SERVER=letsencrypt
# DNS_PROVIDER=cloudflare
# CF_Token=
# CF_Account_ID=
# CF_Zone_ID=
# CPPM_HOST=cppm.example.com
# CPPM_CLIENT_ID=cppm-cert-manager
# CPPM_CLIENT_SECRET=
# CPPM_VERIFY_SSL=false
# CPPM_CERT_PASSPHRASE=ChangeMe!
# CPPM_CALLBACK_HOST=

# Copy to .env and fill in before running with the Traefik overlay.
#
#   cp .env.traefik.example .env
#   docker compose -f docker-compose.yml -f docker-compose.traefik.yml up -d

# Hostname the cert manager UI will be served on (must resolve to this host).
TRAEFIK_HOST=cert-mgr.example.com

# Email address for Let's Encrypt notifications (expiry warnings, etc.)
TRAEFIK_EMAIL=admin@example.com

# ── DNS-01 only — add your DNS provider credentials if using DNS challenge ──
# See the DNS-01 section in docker-compose.traefik.yml for which vars to set.
# CF_Token=
# PORKBUN_API_KEY=
# PORKBUN_SECRET_API_KEY=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
